# Build artifacts
workspace/
dist/
*.img
*.img.xz
*.zip
*.tmp

# Generated files from JSON config
src/variants/*/_generated/
src/modules/*/files/_generated/

# CustomPiOS drops the custompios_path sidecar at build time
src/custompios_path
src/workspace/
src/workspace-*/
src/build.log

# tools/requirements.txt is auto-synced from scripts/requirements.txt by
# the run.* launchers before docker build - so it drifts on every run.
tools/requirements.txt

# CustomPiOS is cloned at build time into this path
CustomPiOS/
!CustomPiOS/.keep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Editor
.vscode/
.idea/
*.swp

# Secrets (just in case)
.env
.env.local
secrets.json
.claude/

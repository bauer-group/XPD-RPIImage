#!/usr/bin/env bash
# bgRPIImage-setup - on-device helper for the most common post-flash changes.
# Installed at /usr/local/sbin/bgRPIImage-setup. Always run with sudo.
#
# Subcommands:
#   password [USER]                        change a user's password (default: admin)
#   wifi SSID [PSK] [COUNTRY]              replace the wpa_supplicant WiFi network
#   wifi --disable                         tear down wifi (keeps wlan0 down)
#   ip IFACE dhcp                          switch an interface to DHCP
#   ip IFACE static CIDR [GATEWAY] [DNS]   assign a static IPv4 (CIDR = addr/prefix)
#   status                                 show current network + identity
#
# All changes are applied via systemd-networkd drop-in files so they survive
# upgrades. Existing files in /etc/systemd/network/ are NOT touched beyond
# replacing the specific bgRPIImage-managed one for the interface.
set -euo pipefail

PROG="${0##*/}"
[[ "$EUID" -eq 0 ]] || { echo "$PROG must run as root (use sudo)" >&2; exit 1; }

CY=$'\033[1;36m'; GR=$'\033[1;32m'; YE=$'\033[1;33m'; RD=$'\033[1;31m'; NC=$'\033[0m'
[[ -t 1 ]] || { CY=''; GR=''; YE=''; RD=''; NC=''; }

info()  { echo "${CY}[*]${NC} $*"; }
ok()    { echo "${GR}[✓]${NC} $*"; }
warn()  { echo "${YE}[!]${NC} $*" >&2; }
die()   { echo "${RD}[x]${NC} $*" >&2; exit 1; }

usage() {
    sed -n '2,18p' "$0" | sed 's/^# \{0,1\}//'
    exit "${1:-0}"
}

# --------------------------------------------------------------------------
cmd_password() {
    local user="${1:-admin}"
    id -u "$user" >/dev/null 2>&1 || die "user '$user' does not exist"
    info "Changing password for '$user'"
    passwd "$user"
    # Clear the default-password warning marker once the operator actually
    # rotates the credential (MOTD stops shouting).
    rm -f /etc/bgRPIImage-default-password-active
    ok "password updated for $user"
}

# --------------------------------------------------------------------------
cmd_wifi() {
    if [[ "${1:-}" == "--disable" ]]; then
        info "Disabling wlan0"
        systemctl disable --now "wpa_supplicant@wlan0.service" 2>/dev/null || true
        ip link set wlan0 down 2>/dev/null || true
        ok "wlan0 down, wpa_supplicant@wlan0 disabled"
        return
    fi

    local ssid="${1:-}" psk="${2:-}" country="${3:-DE}"
    [[ -n "$ssid" ]] || die "usage: $PROG wifi SSID [PSK] [COUNTRY]"

    if [[ -z "$psk" ]]; then
        read -r -s -p "WiFi password for \"$ssid\": " psk; echo
        [[ -n "$psk" ]] || die "empty password"
    fi

    local conf="/etc/wpa_supplicant/wpa_supplicant-wlan0.conf"
    info "Writing $conf"
    # wpa_passphrase produces the hashed psk + keeps the network block clean.
    {
        echo "ctrl_interface=DIR=/var/run/wpa_supplicant GROUP=netdev"
        echo "update_config=1"
        echo "country=$country"
        echo
        wpa_passphrase "$ssid" "$psk" | grep -v '^\s*#psk='
    } > "$conf.tmp"
    install -m 600 "$conf.tmp" "$conf"
    rm -f "$conf.tmp"

    systemctl enable "wpa_supplicant@wlan0.service" >/dev/null 2>&1
    systemctl restart "wpa_supplicant@wlan0.service"
    ok "wifi updated (SSID=$ssid, country=$country); reconnection in progress"
    info "check status with: networkctl status wlan0"
}

# --------------------------------------------------------------------------
cmd_ip() {
    local iface="${1:-}" mode="${2:-}"
    [[ -n "$iface" && -n "$mode" ]] || die "usage: $PROG ip IFACE {dhcp|static CIDR [GW] [DNS]}"
    ip link show "$iface" >/dev/null 2>&1 || die "interface '$iface' does not exist"

    local dropin="/etc/systemd/network/50-bgRPIImage-${iface}.network"
    case "$mode" in
        dhcp)
            info "Configuring $iface for DHCP"
            cat > "$dropin" <<EOF
# Auto-generated by bgRPIImage-setup - edit via \`$PROG ip\` or remove for defaults.
[Match]
Name=$iface

[Network]
DHCP=ipv4
IPv6AcceptRA=yes
LinkLocalAddressing=ipv6
EOF
            ;;
        static)
            local cidr="${3:-}" gw="${4:-}" dns="${5:-1.1.1.1}"
            [[ "$cidr" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/[0-9]+$ ]] \
                || die "CIDR must look like 10.0.0.5/24"
            info "Configuring $iface static $cidr${gw:+ via $gw} (DNS $dns)"
            {
                echo "# Auto-generated by bgRPIImage-setup"
                echo "[Match]"
                echo "Name=$iface"
                echo
                echo "[Network]"
                echo "Address=$cidr"
                [[ -n "$gw" ]] && echo "Gateway=$gw"
                echo "DNS=$dns"
                echo "IPv6AcceptRA=yes"
            } > "$dropin"
            ;;
        *)
            die "unknown mode '$mode' (expected: dhcp | static)"
            ;;
    esac
    chmod 644 "$dropin"
    # The stock 10-eth.network / 20-wlan.network shipped with the image is
    # overridden because systemd-networkd picks the numerically last match
    # for a given [Match]. Our 50- prefix wins.
    info "reloading systemd-networkd"
    networkctl reload
    networkctl reconfigure "$iface" 2>/dev/null || systemctl restart systemd-networkd
    ok "$iface reconfigured; inspect with: networkctl status $iface"
}

# --------------------------------------------------------------------------
cmd_status() {
    if [[ -r /etc/bgRPIImage-release ]]; then
        # shellcheck disable=SC1091
        . /etc/bgRPIImage-release
        echo "${CY}bgRPIImage${NC} ${GR}${BGRPIIMAGE_VARIANT:-?}${NC} v${BGRPIIMAGE_VERSION:-?}"
    fi
    echo "${CY}host:${NC} $(hostname)"
    echo
    networkctl status --no-pager 2>/dev/null | head -30 || ip -br addr
    echo
    echo "${CY}wifi drop-in:${NC} /etc/wpa_supplicant/wpa_supplicant-wlan0.conf"
    echo "${CY}network drop-ins:${NC}"
    ls -1 /etc/systemd/network/*.network 2>/dev/null | sed 's|^|  |' || echo "  (none)"
}

# --------------------------------------------------------------------------
case "${1:-}" in
    password|pw)      shift; cmd_password "$@" ;;
    wifi)             shift; cmd_wifi "$@" ;;
    ip|network)       shift; cmd_ip "$@" ;;
    status|info)      shift; cmd_status "$@" ;;
    -h|--help|help|"") usage 0 ;;
    *)                usage 2 ;;
esac

#!/usr/bin/env bash
# bgrpiimage-portainer: deploy Portainer CE/EE as a Docker-native service.
#
# Design decision: no always-running systemd unit. Portainer runs as a
# docker-compose service with `restart: unless-stopped`, which means the
# Docker daemon itself (once started by the OS) brings the container back
# up on every boot. We only ship:
#   - /etc/bgrpiimage/portainer/docker-compose.yml  (declarative config)
#   - bgrpiimage-portainer-install.service           (oneshot, first boot)
# After the oneshot fires once, it sentinel-marks itself done and stays
# out of the way forever.
set -x
set -e
export LC_ALL=C

source /common.sh
install_cleanup_trap

# Deploy this module's files from the copied /filesystem/root tree
# (CustomPiOS copies module/filesystem/ into the chroot root) to
# their real destinations under /.
unpack /filesystem/root / root

GEN=/opt/bgrpiimage/bgrpiimage-portainer

install -D -m 644 "$GEN/docker-compose.yml" /etc/bgrpiimage/portainer/docker-compose.yml
install -D -m 644 "$GEN/bgrpiimage-portainer-install.service" \
    /etc/systemd/system/bgrpiimage-portainer-install.service
if [[ -f "$GEN/portainer.env" ]]; then
    install -D -m 644 "$GEN/portainer.env" /etc/default/portainer
fi

# shellcheck disable=SC1091
source "$GEN/portainer.env" 2>/dev/null || true

if [[ "${BGRPIIMAGE_PORTAINER_AUTOSTART:-yes}" == "yes" ]]; then
    systemctl enable bgrpiimage-portainer-install.service
fi

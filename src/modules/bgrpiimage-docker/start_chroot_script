#!/usr/bin/env bash
# bgrpiimage-docker: install Docker CE from the official Debian repo.
# Raspberry Pi OS derives from Debian, so we use download.docker.com/linux/debian
# (not /ubuntu as in the snippet - that would install ubuntu packages that
# conflict with Debian libc on arm64).
set -x
set -e
export LC_ALL=C
export DEBIAN_FRONTEND=noninteractive

source /common.sh
install_cleanup_trap

# Deploy this module's files from the copied /filesystem/root tree
# (CustomPiOS copies module/filesystem/ into the chroot root) to
# their real destinations under /.
unpack /filesystem/root / root

GEN=/opt/bgrpiimage/bgrpiimage-docker

# Remove any conflicting distro-provided docker packages.
for pkg in docker.io docker-doc docker-compose docker-compose-v2 podman-docker containerd runc; do
    apt-get remove -y "$pkg" 2>/dev/null || true
done

install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc
chmod a+r /etc/apt/keyrings/docker.asc

CODENAME=$(. /etc/os-release && echo "$VERSION_CODENAME")
ARCH=$(dpkg --print-architecture)
echo "deb [arch=${ARCH} signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/debian ${CODENAME} stable" \
    > /etc/apt/sources.list.d/docker.list

apt-get update
apt-get install -y --no-install-recommends \
    docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

# sysctl drop-in (vm.max_map_count etc.)
if [[ -f "$GEN/98-docker.conf" ]]; then
    install -D -m 644 "$GEN/98-docker.conf" /etc/sysctl.d/98-docker.conf
fi

# daemon.json
if [[ -f "$GEN/daemon.json" ]]; then
    install -D -m 644 "$GEN/daemon.json" /etc/docker/daemon.json
fi

# IPv6 NAT helper
if [[ -f "$GEN/docker-support.service" ]]; then
    install -D -m 644 "$GEN/docker-support.service" /usr/lib/systemd/system/docker-support.service
    systemctl enable docker-support.service
fi

systemctl enable docker

# post-boot network creation (runs once on target hardware, not in chroot)
if [[ -f "$GEN/create-networks.sh" ]]; then
    install -D -m 755 "$GEN/create-networks.sh" /usr/local/sbin/bgrpiimage-docker-networks.sh
    cat > /etc/systemd/system/bgrpiimage-docker-networks.service <<'__EOF__'
[Unit]
Description=BAUER GROUP docker network bootstrap
Requires=docker.service
After=docker.service docker-support.service
ConditionPathExists=!/var/lib/bgRPIImage/docker-networks.done

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/bgrpiimage-docker-networks.sh
ExecStartPost=/bin/sh -c "mkdir -p /var/lib/bgRPIImage && touch /var/lib/bgRPIImage/docker-networks.done"
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
__EOF__
    systemctl enable bgrpiimage-docker-networks.service
fi

apt-get clean

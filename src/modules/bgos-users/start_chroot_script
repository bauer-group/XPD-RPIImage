#!/usr/bin/env bash
# bgos-users: create users, configure sudo/su, harden sshd
set -x
set -e
export LC_ALL=C
export DEBIAN_FRONTEND=noninteractive

source /common.sh
install_cleanup_trap

GEN=/bgos-users/files/_generated

# Stage pam_su drop-in where the create-users script expects it.
if [[ -f "$GEN/pam_su" ]]; then
    install -m 644 "$GEN/pam_su" /tmp/_bgos_su_pam
fi

bash "$GEN/create-users.sh"
rm -f /tmp/_bgos_su_pam

#!/usr/bin/env bash
# bgos-boot: append dtoverlays / dtparam entries to firmware config.txt.
# Uses a fenced block so subsequent generator runs can replace it idempotently.
set -x
set -e
export LC_ALL=C

source /common.sh
install_cleanup_trap

GEN=/bgos-boot/files/_generated
CFG="${BGOS_BOOT_CONFIG_PATH:-/boot/firmware/config.txt}"

# Fallback for images that still use the legacy path.
if [[ ! -f "$CFG" && -f /boot/config.txt ]]; then
    CFG=/boot/config.txt
fi
if [[ ! -f "$CFG" ]]; then
    echo "bgos-boot: no config.txt found - skipping"
    exit 0
fi

START_MARK="# >>> BGOS AUTO-GENERATED >>>"
END_MARK="# <<< BGOS AUTO-GENERATED <<<"

# Strip any previous BGOS block.
if grep -qF "$START_MARK" "$CFG"; then
    sed -i "/${START_MARK//\//\\/}/,/${END_MARK//\//\\/}/d" "$CFG"
fi

{
    printf '\n%s\n' "$START_MARK"
    cat "$GEN/config-bgos.txt"
    printf '%s\n' "$END_MARK"
} >> "$CFG"

#!/usr/bin/env bash
# bgrpiimage-hardware: runtime side of the hardware blocks.
#
# The config.txt-level lines (dtoverlay=i2c-rtc,*, overclock, fan overlays,
# leds, pcie, camera_auto_detect, ...) are emitted by bgrpiimage-boot. This
# module handles everything that is NOT a config.txt line:
#   - RTC userspace: hwclock + fake-hwclock fallback
#   - watchdog: systemd RuntimeWatchdogSec / RebootWatchdogSec
#   - EEPROM bootloader: rpi-eeprom-config on first boot (Pi5 only)
#   - default ALSA sink selection (audio.default_output)
#
# Everything is idempotent and driven by /opt/bgrpiimage/bgrpiimage-hardware/hardware.env
# which is generated by scripts/generate.py from the resolved variant JSON.
set -x
set -e
export LC_ALL=C
export DEBIAN_FRONTEND=noninteractive

source /common.sh
install_cleanup_trap

unpack /filesystem/root / root

GEN=/opt/bgrpiimage/bgrpiimage-hardware

# shellcheck disable=SC1091
source "$GEN/hardware.env"

apt-get update
if [[ -f "$GEN/packages.list" ]]; then
    xargs -a "$GEN/packages.list" -r apt-get install -y --no-install-recommends
fi

# --- RTC ---------------------------------------------------------------------
# The dtoverlay (config.txt) wires up the device on I2C. On the userspace side
# we want hwclock-on-boot to sync system time from the RTC (util-linux's
# hwclock.service handles this automatically once the device node exists).
# fake-hwclock provides a reasonable fallback for devices without an RTC HAT.
if [[ "${BGRPIIMAGE_RTC_ENABLED:-no}" == "yes" ]]; then
    systemctl enable hwclock.service 2>/dev/null || true
fi
if [[ "${BGRPIIMAGE_RTC_FAKE_HWCLOCK:-no}" == "yes" ]]; then
    # fake-hwclock is a boot-time service that saves/loads /etc/fake-hwclock.data;
    # Debian's package ships the systemd unit pre-enabled, so just make sure
    # it's installed (handled via packages.list above).
    systemctl enable fake-hwclock.service 2>/dev/null || true
fi

# --- Watchdog ----------------------------------------------------------------
# Configure systemd's built-in watchdog integration. The kernel exposes
# /dev/watchdog via the bcm2835-wdt driver; systemd-pid1 kicks it when
# RuntimeWatchdogSec > 0. RebootWatchdogSec caps the orderly shutdown.
if [[ "${BGRPIIMAGE_WATCHDOG_ENABLED:-no}" == "yes" ]]; then
    mkdir -p /etc/systemd/system.conf.d
    cat > /etc/systemd/system.conf.d/10-bgrpiimage-watchdog.conf <<EOF
# Auto-generated by bgrpiimage-hardware - do not edit by hand.
[Manager]
RuntimeWatchdogSec=${BGRPIIMAGE_WATCHDOG_RUNTIME_SEC:-10}
RebootWatchdogSec=${BGRPIIMAGE_WATCHDOG_REBOOT_SEC:-120}
EOF
fi

# --- EEPROM bootloader (Pi5 / CM5) ------------------------------------------
# rpi-eeprom-config is not available until the first real boot (the chroot
# doesn't have access to the target EEPROM), so we stage a oneshot service.
if [[ -f "$GEN/eeprom.env" ]]; then
    install -D -m 644 "$GEN/eeprom.env" /etc/bgrpiimage/eeprom.env
    install -D -m 644 "$GEN/bgrpiimage-eeprom-apply.service" \
        /etc/systemd/system/bgrpiimage-eeprom-apply.service
    install -D -m 755 "$GEN/bgrpiimage-eeprom-apply.sh" \
        /usr/local/sbin/bgrpiimage-eeprom-apply
    systemctl enable bgrpiimage-eeprom-apply.service
fi

# --- Default ALSA sink ------------------------------------------------------
if [[ -n "${BGRPIIMAGE_AUDIO_DEFAULT_OUTPUT:-}" && "${BGRPIIMAGE_AUDIO_DEFAULT_OUTPUT}" != "auto" ]]; then
    mkdir -p /etc/alsa/conf.d
    case "${BGRPIIMAGE_AUDIO_DEFAULT_OUTPUT}" in
        hdmi0)      pcm="sysdefault:CARD=vc4hdmi0";;
        hdmi1)      pcm="sysdefault:CARD=vc4hdmi1";;
        headphones) pcm="sysdefault:CARD=Headphones";;
        dac)        pcm="sysdefault:CARD=DAC";;
        *)          pcm="";;
    esac
    if [[ -n "$pcm" ]]; then
        cat > /etc/alsa/conf.d/99-bgrpiimage-default.conf <<EOF
# Auto-generated by bgrpiimage-hardware.
pcm.!default { type plug; slave.pcm "${pcm}"; }
ctl.!default { type hw;   card 0; }
EOF
    fi
fi

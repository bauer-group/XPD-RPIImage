#!/usr/bin/env bash
# bgrpiimage-can: install can-utils and drop systemd-networkd configs for can0/can1.
# systemd-networkd handles both link setup (TransmitQueueLength) and the
# [CAN] block (bitrate). Alternative would be /etc/network/interfaces.d -
# but we already standardize on networkd, so we stay consistent.
set -x
set -e
export LC_ALL=C
export DEBIAN_FRONTEND=noninteractive

source /common.sh
install_cleanup_trap

GEN=/bgrpiimage-can/files/_generated

apt-get update
if [[ -f "$GEN/packages.list" ]]; then
    xargs -a "$GEN/packages.list" -r apt-get install -y --no-install-recommends
fi

mkdir -p /etc/systemd/network
cp -a "$GEN/systemd-networkd/." /etc/systemd/network/

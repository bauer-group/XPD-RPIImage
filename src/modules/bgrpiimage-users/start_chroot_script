#!/usr/bin/env bash
# bgrpiimage-users: create users, configure sudo/su, harden sshd
set -x
set -e
export LC_ALL=C
export DEBIAN_FRONTEND=noninteractive

source /common.sh
install_cleanup_trap

# Deploy this module's files from the copied /filesystem/root tree
# (CustomPiOS copies module/filesystem/ into the chroot root) to
# their real destinations under /.
unpack /filesystem/root / root

GEN=/opt/bgrpiimage/bgrpiimage-users

# Stage pam_su drop-in where the create-users script expects it.
if [[ -f "$GEN/pam_su" ]]; then
    install -m 644 "$GEN/pam_su" /tmp/_bgrpiimage_su_pam
fi

bash "$GEN/create-users.sh"
rm -f /tmp/_bgrpiimage_su_pam

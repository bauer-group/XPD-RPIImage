#!/usr/bin/env bash
# bgos-base: hostname, locale, timezone, apt packages
set -x
set -e
export LC_ALL=C
export DEBIAN_FRONTEND=noninteractive

source /common.sh
install_cleanup_trap

GEN=/bgos-base/files/_generated

# --- hostname ---
if [[ -f "$GEN/hostname" ]]; then
    install -m 644 "$GEN/hostname" /etc/hostname
    sed -i "s/127\.0\.1\.1.*/127.0.1.1\t$(cat "$GEN/hostname")/" /etc/hosts \
        || echo -e "127.0.1.1\t$(cat "$GEN/hostname")" >> /etc/hosts
fi

# --- locale & timezone ---
if [[ -f "$GEN/locale.env" ]]; then
    # shellcheck disable=SC1090
    source "$GEN/locale.env"
    ln -sf "/usr/share/zoneinfo/$BGOS_TIMEZONE" /etc/localtime
    echo "$BGOS_TIMEZONE" > /etc/timezone
    sed -i "s/^# *\(${BGOS_LOCALE//./\\.} \)/\1/" /etc/locale.gen || true
    locale-gen "$BGOS_LOCALE" || true
    update-locale "LANG=$BGOS_LOCALE" "LC_ALL=$BGOS_LOCALE"
    # Keyboard layout (non-fatal if the package is absent on minimal images)
    if [[ -f /etc/default/keyboard ]]; then
        sed -i "s/^XKBLAYOUT=.*/XKBLAYOUT=\"$BGOS_KEYBOARD\"/" /etc/default/keyboard
    fi
fi

# --- apt packages ---
apt-get update
if [[ -f "$GEN/packages.list" ]]; then
    xargs -a "$GEN/packages.list" -r apt-get install -y --no-install-recommends
fi
if [[ -n "${BGOS_BASE_EXTRA_PACKAGES:-}" ]]; then
    # shellcheck disable=SC2086
    apt-get install -y --no-install-recommends $BGOS_BASE_EXTRA_PACKAGES
fi
apt-get clean

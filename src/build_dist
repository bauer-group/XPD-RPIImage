#!/usr/bin/env bash
# bgRPIImage - entrypoint wrapper invoked by scripts/build.sh inside the
# guysoft/custompios sibling container.
#
# Pattern mirrors OctoPi: we set DIST_PATH to this src/ directory, read
# CUSTOM_PI_OS_PATH from the custompios_path sidecar file that
# `update-custompios-paths` wrote, and delegate to CustomPiOS's
# build_custom_os entrypoint.
set -euo pipefail

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

export DIST_PATH="${DIR}"
if [[ ! -f "${DIR}/custompios_path" ]]; then
    echo "error: ${DIR}/custompios_path is missing." >&2
    echo "       run: bash CustomPiOS/src/update-custompios-paths src" >&2
    exit 2
fi
export CUSTOM_PI_OS_PATH=$(<"${DIR}/custompios_path")
export PATH="${PATH}:${CUSTOM_PI_OS_PATH}"

# Explicitly seed BASE_WORKSPACE so CustomPiOS never ends up with an empty
# value. When a board variant sets BASE_IGNORE_VARIANT_NAME=yes (as
# raspios_lite_arm64 does), the built-in `|| BASE_WORKSPACE=...` fallback
# in CustomPiOS/src/config:97 can be bypassed, producing `mkdir -p` with
# no argument at startup. We pin the workspace path here from the variant
# arg ($1) where it is always known.
_bgrpi_variant="${1:-default}"
if [[ "${_bgrpi_variant}" == "default" ]]; then
    export BASE_WORKSPACE="${DIST_PATH}/workspace"
else
    export BASE_WORKSPACE="${DIST_PATH}/workspace-${_bgrpi_variant}"
fi
# CustomPiOS's own fallback (src/config:99) for BASE_MOUNT_PATH is also
# not firing reliably in our environment, so seed it too.
export BASE_MOUNT_PATH="${BASE_WORKSPACE}/mount"
unset _bgrpi_variant

echo "[bgRPIImage] DIST_PATH=${DIST_PATH}"
echo "[bgRPIImage] CUSTOM_PI_OS_PATH=${CUSTOM_PI_OS_PATH}"
echo "[bgRPIImage] BASE_WORKSPACE=${BASE_WORKSPACE}"
echo "[bgRPIImage] BASE_MOUNT_PATH=${BASE_MOUNT_PATH}"

exec "${CUSTOM_PI_OS_PATH}/build_custom_os" "$@"

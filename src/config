# bgRPIImage - distro-level CustomPiOS config.
# Sourced by CustomPiOS's build script before the selected variant's config.

# Distro identity (variant config may refine DIST_NAME / VERSION).
export DIST_NAME="bgrpiimage"
export DIST_VERSION="0.1.0"

# BASE_BOARD -> key into CustomPiOS/src/images.yml. All current variants use
# arm64 on Raspberry Pi hardware (Pi 4, Pi 5, Pi Zero 2W, CM4, CM5).
export BASE_BOARD="raspberrypiarm64"
export BASE_ARCH="arm64"

# Expand the rootfs to make room for Docker images, CAN tooling, etc.
# Values are in megabytes.
export BASE_IMAGE_ENLARGEROOT="${BASE_IMAGE_ENLARGEROOT:-2000}"
export BASE_IMAGE_RESIZEROOT="${BASE_IMAGE_RESIZEROOT:-200}"

# Partition layout of the downloaded raspios image. These defaults live in
# CustomPiOS's own `base` module (src/modules/base/config) which we do NOT
# include - we ship our own bgrpiimage-base. Without these, enlarge_ext
# gets the wrong arg ($BASE_IMAGE_ENLARGEROOT shifts into the partition
# slot) and fails with "operand expected" during sfdisk/jq parsing.
export BASE_ROOT_PARTITION="${BASE_ROOT_PARTITION:-2}"
export BASE_BOOT_PARTITION="${BASE_BOOT_PARTITION:-1}"

export LC_ALL=C

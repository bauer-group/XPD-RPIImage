# =============================================================================
# BAUER GROUP XPD-RPIImage - environment variable template
#
# Copy this file to .env and fill in real values. The generator resolves
# ${VAR} / ${VAR:-default} references inside the variant JSON at build time.
# Unresolved required variables (no default) fail the build fast.
#
# .env is gitignored - do NOT commit it.
# =============================================================================

# --- credentials baked into the image ------------------------------------
# Admin user password set via chpasswd in the bgrpiimage-users module.
# Referenced by every variant's users[].password.
ADMIN_PASSWORD=12345678

# Pre-shared key for the WiFi network configured via wpa_supplicant.
# Referenced by network.wifi.networks[].psk.
WIFI_PSK=12345678

# --- optional: pin CustomPiOS toolchain (docker image + git ref) ---------
# Defaults track master.  For reproducible builds pin to a specific commit
# SHA of github.com/guysoft/CustomPiOS and a digest of the docker image.
# DOCKER_IMAGE=guysoft/custompios:devel
# CUSTOMPIOS_REF=master

# --- optional: tools container image name --------------------------------
# BGRPIIMAGE_TOOLS_IMAGE=bgrpiimage-tools

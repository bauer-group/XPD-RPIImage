        <article class="card">
          <header>
            <h2>{{variant}}</h2>
            <span class="tag">{{tag}}</span>
          </header>
          <p class="description">{{description}}</p>
          <dl class="meta">
            <dt>Hostname</dt><dd><code>{{hostname}}</code></dd>
            <dt>Targets</dt><dd>{{targets}}</dd>
            <dt>Download size</dt><dd>{{download_mib}} MiB</dd>
            <dt>Extracted size</dt><dd>{{extract_mib}} MiB</dd>
            <dt>Release date</dt><dd>{{release_date}}</dd>
          </dl>
          <div class="checksums">
            <div><span class="label">SHA-256 (.img.xz)</span><code>{{download_sha256}}</code></div>
            <div><span class="label">SHA-256 (.img)</span><code>{{extract_sha256}}</code></div>
          </div>
          <div class="actions">
            <a class="btn primary" href="{{image_url}}">⬇ Download .img.xz</a>
            <a class="btn"         href="{{sha256_url}}">.sha256</a>
            <a class="btn"         href="{{manifest_url}}">manifest.json</a>
          </div>
        </article>

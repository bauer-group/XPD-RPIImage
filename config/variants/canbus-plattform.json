{
  "$schema": "../schema.json",
  "extends": "./base.json",
  "variant": {
    "name": "canbus-plattform",
    "description": "BAUER GROUP CANbus plattform - base image + Waveshare 17912 dual isolated CAN HAT (MCP2515 on SPI)"
  },
  "hostname": "bg-canbus",
  "users": [
    {
      "name": "admin",
      "password": "${ADMIN_PASSWORD:-12345678}",
      "groups": ["dialout", "gpio", "i2c", "spi"],
      "shell": "/bin/bash",
      "sudo_nopasswd": true
    }
  ],
  "packages": ["can-utils"],
  "boot_config": {
    "enable_spi": true,
    "dtoverlays": [
      { "name": "mcp2515-can0", "params": { "oscillator": "16000000", "interrupt": "25" } },
      { "name": "mcp2515-can1", "params": { "oscillator": "16000000", "interrupt": "26" } }
    ]
  },
  "can": {
    "interfaces": [
      { "name": "can0", "bitrate": 500000, "auto_up": true, "txqueuelen": 65535 },
      { "name": "can1", "bitrate": 500000, "auto_up": true, "txqueuelen": 65535 }
    ]
  }
}
